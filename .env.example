# Copy this file to .env.local and fill in your Supabase project settings.
# Find these values in Supabase Dashboard -> Project Settings -> API.
# Leave them empty for local-only demo data and browser localStorage fallback.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
